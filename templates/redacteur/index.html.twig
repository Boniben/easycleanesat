{% from '_macros/action_buttons.html.twig' import action_buttons %}
﻿{% extends 'base.html.twig' %}

{% block title %}Redacteur index{% endblock %}

{% block body %}
    <h1>Redacteur index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Initial</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for redacteur in redacteurs %}
            <tr>
                <td>{{ redacteur.id }}</td>
                <td>{{ redacteur.initial }}</td>
                <td>

                    {{ action_buttons('app_redacteur_show', 'app_redacteur_edit', redacteur.id) }}

                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_redacteur_new') }}">Creer</a>
{% endblock %}
