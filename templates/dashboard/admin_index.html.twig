{% extends 'base.html.twig' %}

{% block title %}Dashboard Admin{% endblock %}

{% block body %}
    <div style="display: flex; justify-content: flex-end; margin-bottom: 16px;">
        <a href="{{ path('app_logout') }}" class="btn btn-danger">Deconnexion</a>
    </div>

    <section class="dashboard-hero">
        <h1>Dashboard Administrateur</h1>
        <p>Acces rapide aux espaces de gestion.</p>
    </section>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px;">
        <section style="background: #ffffff; border: 1px solid #d1d5db; border-radius: 16px; padding: 20px;">
            <h2 style="margin: 0 0 8px; font-size: 1.2rem;">Necessaire</h2>
            <p style="margin: 0 0 16px; color: #6b7280;">Acces direct a la gestion des necessaires.</p>
            <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                <a href="{{ path('app_necessaire_index') }}" class="btn btn-outline-primary">Consulter les necessaires</a>
            </div>
        </section>

        <section style="background: #ffffff; border: 1px solid #d1d5db; border-radius: 16px; padding: 20px;">
            <h2 style="margin: 0 0 8px; font-size: 1.2rem;">Produit</h2>
            <p style="margin: 0 0 16px; color: #6b7280;">Acces direct aux ecrans produits et dosage.</p>
            <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                <a href="{{ path('app_produit_index') }}" class="btn btn-outline-primary">Produits</a>
                <a href="{{ path('app_meo_produit_index') }}" class="btn btn-outline-primary">Meo produit</a>
                <a href="{{ path('app_moyen_dosage_index') }}" class="btn btn-outline-primary">Moyen dosage</a>
                <a href="{{ path('app_contenant_index') }}" class="btn btn-outline-primary">Contenants</a>
                <a href="{{ path('app_temps_contact_index') }}" class="btn btn-outline-primary">Temps contact</a>
            </div>
        </section>

        <section style="background: #ffffff; border: 1px solid #d1d5db; border-radius: 16px; padding: 20px;">
            <h2 style="margin: 0 0 8px; font-size: 1.2rem;">Intervention</h2>
            <p style="margin: 0 0 16px; color: #6b7280;">Acces direct a la gestion des interventions.</p>
            <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                <a href="{{ path('app_intervention_index') }}" class="btn btn-outline-primary">Interventions</a>
                <a href="{{ path('app_element_securite_index') }}" class="btn btn-outline-primary">Element securite</a>
            </div>
        </section>

        <section style="background: #ffffff; border: 1px solid #d1d5db; border-radius: 16px; padding: 20px;">
            <h2 style="margin: 0 0 8px; font-size: 1.2rem;">Client</h2>
            <p style="margin: 0 0 16px; color: #6b7280;">Acces direct aux donnees clients et contrats.</p>
            <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                <a href="{{ path('app_client_index') }}" class="btn btn-outline-primary">Clients</a>
                <a href="{{ path('app_contrat_index') }}" class="btn btn-outline-primary">Contrats</a>
                <a href="{{ path('app_type_zone_index') }}" class="btn btn-outline-primary">Type zone</a>
                <a href="{{ path('app_type_support_index') }}" class="btn btn-outline-primary">Type support</a>
            </div>
        </section>
    </div>
{% endblock %}
