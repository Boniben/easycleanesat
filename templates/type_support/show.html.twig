{% extends 'base.html.twig' %}
{% block title %}Type de support
{% endblock %}
{% block body %}
	<div class="page-header">
		<h1>{{ type_support.nom }}</h1>
	</div>
	<div class="card">
		<ul class="info-list">
			<li>
				<span class="info-label">Nom :</span>
				<span>{{ type_support.nom }}</span>
			</li>
			<li>
				<span class="info-label">Description :</span>
				<span>{{ type_support.description ?? 'Aucune' }}</span>
			</li>
		</ul>
	</div>
	<div class="btn-group mt-3">
		<a href="{{ path('app_type_support_index') }}" class="btn btn-secondary">Retour a la liste</a>
		<a href="{{ path('app_type_support_edit', {'id': type_support.id}) }}" class="btn btn-secondary">Modifier</a>
		{{ include('type_support/_delete_form.html.twig') }}
	</div>
{% endblock %}
