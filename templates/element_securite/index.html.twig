{% from '_macros/action_buttons.html.twig' import action_buttons %}
﻿{% extends 'base.html.twig' %}

{% block title %}ElementSecurite index{% endblock %}

{% block body %}
    <h1>ElementSecurite index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Picto</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for element_securite in element_securites %}
            <tr>
                <td>{{ element_securite.id }}</td>
                <td>{{ element_securite.nom }}</td>
                <td>
                    {% set pictoFile = element_securite.picto ? element_securite.picto : (element_securite.id ~ '.png') %}
                    <div class="tile-item-display">
                        <img src="{{ asset('PictoElementSecuritePNG/' ~ pictoFile) }}" alt="{{ element_securite.nom }}" class="tile-picto" onerror="this.style.display='none'">
                    </div>
                </td>
                <td>

                    {{ action_buttons('app_element_securite_show', 'app_element_securite_edit', element_securite.id) }}

                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_element_securite_new') }}">Creer</a>

<style>
.tile-item-display {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    padding: 0.4rem 0.6rem;
    border: 2px solid #d0d4db;
    border-radius: 6px;
    background: #fff;
}
.tile-picto {
    width: 48px;
    height: 48px;
    object-fit: contain;
    display: block;
}
</style>
{% endblock %}
