{% extends 'base.html.twig' %}

{% block title %}ElementSecurite{% endblock %}

{% block body %}
    <h1>ElementSecurite</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ element_securite.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ element_securite.nom }}</td>
            </tr>
            <tr>
                <th>Picto</th>
                <td>
                    {% set pictoFile = element_securite.picto ? element_securite.picto : (element_securite.id ~ '.png') %}
                    <div class="tile-item-display">
                        <img src="{{ asset('PictoElementSecuritePNG/' ~ pictoFile) }}" alt="{{ element_securite.nom }}" class="tile-picto" onerror="this.style.display='none'">
                        <span>{{ element_securite.nom }}</span>
                    </div>
                </td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_element_securite_index') }}">Retour a la liste</a>

    <a href="{{ path('app_element_securite_edit', {'id': element_securite.id}) }}">Modifier</a>

    {{ include('element_securite/_delete_form.html.twig') }}

<style>
.tile-item-display {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 0.5rem 0.8rem;
    border: 2px solid #d0d4db;
    border-radius: 6px;
    background: #fff;
    font-size: 0.85rem;
    font-weight: 600;
    color: #1e2028;
}
.tile-picto {
    width: 48px;
    height: 48px;
    object-fit: contain;
    display: block;
}
</style>
{% endblock %}
