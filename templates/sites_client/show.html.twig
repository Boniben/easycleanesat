{% extends 'base.html.twig' %}

{% block title %}{{ sites_client.nom }}{% endblock %}

{% block body %}
	<div class="page-header">
		<div>
			<h1>{{ sites_client.nom }}</h1>
			<p class="text-muted text-sm">{{ sites_client.client.nom }}</p>
		</div>
		<div class="btn-group">
			<a href="{{ path('app_intervention_new', {'sites_client_id': sites_client.id}) }}" class="btn btn-success">+ Nouvelle intervention</a>
			<a href="{{ path('app_sites_client_edit', {'id': sites_client.id}) }}" class="btn btn-secondary">Modifier</a>
		</div>
	</div>

	<div class="btn-group mt-3">
		<a href="{{ path('app_sites_client_index') }}" class="btn btn-secondary">← Retour à la liste</a>
		{{ include('sites_client/_delete_form.html.twig') }}
	</div>
{% endblock %}
