{% extends 'base.html.twig' %}
{% block title %}Types de zone
{% endblock %}
{% block body %}
	<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
		<h1>Types de zone</h1>
		<a href="{{ path('app_type_zone_new') }}" class="btn btn-primary">+ Creer</a>
	</div>

	<table class="table">
		<thead>
			<tr>
				<th>Id</th>
				<th>Picto</th>
				<th>Nom</th>
				<th>Description</th>
				<th>Actions</th>
			</tr>
		</thead>
		<tbody>
			{% for type_zone in type_zones %}
				<tr>
					<td>{{ type_zone.id }}</td>
					<td>
						{% if type_zone.picto %}
							<img src="{{ asset('PictoTypeZonePNG/' ~ type_zone.picto) }}" alt="{{ type_zone.nom }}" style="max-height: 40px;">
						{% else %}
							-
						{% endif %}
					</td>
					<td>{{ type_zone.nom }}</td>
					<td>{{ type_zone.description ?? '' }}</td>
					<td>
						<div class="btn-group">
							<a href="{{ path('app_type_zone_show', {'id': type_zone.id}) }}" class="btn btn-secondary">Voir</a>
							<a href="{{ path('app_type_zone_edit', {'id': type_zone.id}) }}" class="btn btn-secondary">Modifier</a>
						</div>
					</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="5">Aucun type de zone</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>
{% endblock %}
