{% extends 'base.html.twig' %}
{% from '_macros/action_buttons.html.twig' import action_buttons %}

{% block title %}Types de zone
{% endblock %}

{% block body %}
	<div class="page-header">
		<h1>Types de zone</h1>
		{% if app.user and is_granted('ROLE_ADMIN') %}
			<a href="{{ path('app_type_zone_new') }}" class="btn btn-primary">+ Ajouter un type</a>
		{% endif %}
	</div>

	<div class="table-wrapper">
		<table>
			<thead>
				<tr>
					<th>#</th>
					<th>Nom</th>
					<th>Actions</th>
				</tr>
			</thead>
			<tbody>
				{% for type_zone in type_zones %}
					<tr>
						<td>{{ loop.index }}</td>
						<td>{{ type_zone.nom }}</td>
						<td>
						{{ action_buttons('app_type_zone_show', 'app_type_zone_edit', type_zone.id, true) }}
						</td>
					</tr>
				{% else %}
					<tr>
						<td colspan="3">Aucun type de zone trouvé</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
	</div>
{% endblock %}
