<div data-controller="intervention-form"
     data-intervention-form-sites-url-value="{{ path('api_sites_by_client', {'clientId': '__CLIENT_ID__'}) }}"
     data-intervention-form-contrats-url-value="{{ path('api_contrats_by_site', {'siteId': '__SITE_ID__'}) }}"
     data-intervention-form-zones-url-value="{{ path('api_zones_by_site', {'siteId': '__SITE_ID__'}) }}">
{{ form_start(form) }}
    <div{% if is_edit is defined and is_edit %} style="display:none"{% endif %}>
        {{ form_label(form.client) }}
        {{ form_widget(form.client, {
            'attr': {
                'data-intervention-form-target': 'client',
                'data-action': 'change->intervention-form#onClientChange'
            }
        }) }}
        {{ form_errors(form.client) }}
    </div>
    
    <div{% if is_edit is defined and is_edit %} style="display:none"{% endif %}>
        {{ form_label(form.site) }}
        {{ form_widget(form.site, {
            'attr': {
                'data-intervention-form-target': 'site',
                'data-action': 'change->intervention-form#onSiteChange'
            }
        }) }}
        {{ form_errors(form.site) }}
    </div>
    
    <div{% if is_edit is defined and is_edit %} style="display:none"{% endif %}>
        {{ form_label(form.contrat) }}
        {{ form_widget(form.contrat, {
            'attr': {
                'data-intervention-form-target': 'contrat'
            }
        }) }}
        {{ form_errors(form.contrat) }}
    </div>
    
    <div{% if is_edit is defined and is_edit %} style="display:none"{% endif %}>
        {{ form_label(form.zonesClient) }}
        {{ form_widget(form.zonesClient, {
            'attr': {
                'data-intervention-form-target': 'zone'
            }
        }) }}
        {{ form_errors(form.zonesClient) }}
    </div>
    {{ form_row(form.redacteur) }}
    {{ form_row(form.dateCreation) }}
    {{ form_row(form.nbTravailleur) }}
    
    <div class="form-group">
        <label>Durée</label>
        <div class="duree-container">
            {{ form_widget(form.dureeHeure, {'attr': {'class': 'duree-input'}}) }}
            <span class="duree-separator">:</span>
            {{ form_widget(form.dureeMinute, {'attr': {'class': 'duree-input'}}) }}
        </div>
        {{ form_errors(form.dureeHeure) }}
        {{ form_errors(form.dureeMinute) }}
    </div>
    
    <div class="form-group">
        <label>Éléments de sécurité</label>
        {{ form_widget(form.elementSecurites, {'attr': {'class': 'tile-select-hidden', 'id': 'tile-select-elementSecurites', 'style': 'display:none!important'}}) }}
        {{ form_errors(form.elementSecurites) }}
        <div class="tile-grid" id="es-tile-grid">
            {% for choice in form.elementSecurites.vars.choices %}
                <div class="tile-item{% if choice.value in form.elementSecurites.vars.value %} selected{% endif %}"
                     data-tile-value="{{ choice.value }}"
                     onclick="esTileToggle(this)">
                    {% set pictoFile = choice.data.picto ? choice.data.picto : (choice.data.id ~ '.png') %}
                    <img src="{{ asset('PictoElementSecuritePNG/' ~ pictoFile) }}" alt="{{ choice.label }}" class="tile-picto" onerror="this.style.display='none'">
                    <span>{{ choice.label }}</span>
                </div>
            {% endfor %}
        </div>
    </div>

    <button class="btn btn-primary">{{ button_label|default('Save') }}</button>
{{ form_end(form) }}

<style>
.duree-container { display: flex; align-items: center; gap: 10px; }
.duree-input { width: 80px; padding: 8px; font-size: 1.2em; text-align: center; border: 1px solid #ccc; border-radius: 4px; }
.duree-separator { font-size: 1.5em; font-weight: bold; color: #333; }
.tile-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
    gap: 0.5rem;
    margin-top: 0.4rem;
}
.tile-item {
    padding: 0.5rem 0.6rem;
    border: 2px solid #d0d4db;
    border-radius: 6px;
    background: #fff;
    font-size: 0.82rem;
    font-weight: 600;
    text-align: center;
    cursor: pointer !important;
    user-select: none;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
    color: #1e2028;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
}
.tile-picto {
    width: 48px;
    height: 48px;
    object-fit: contain;
    display: block;
}
.tile-item:hover {
    border-color: #3d5a80;
    background: #dce4ed;
    color: #2c4460;
}
.tile-item.selected {
    border-color: #3d5a80 !important;
    background: #3d5a80 !important;
    color: #fff !important;
    box-shadow: 0 2px 8px rgba(61,90,128,0.35);
}
</style>

<script>
function esTileToggle(tile) {
    var isNow = !tile.classList.contains('selected');
    tile.classList.toggle('selected', isNow);
    var select = document.getElementById('tile-select-elementSecurites');
    if (!select) return;
    var val = tile.getAttribute('data-tile-value');
    Array.from(select.options).forEach(function(opt) {
        if (opt.value === val) opt.selected = isNow;
    });
}
</script>
