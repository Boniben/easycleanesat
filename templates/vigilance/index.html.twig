{% from '_macros/action_buttons.html.twig' import action_buttons %}
﻿{% extends 'base.html.twig' %}

{% block title %}Vigilance index{% endblock %}

{% block body %}
    <h1>Vigilance index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Definition</th>
                <th>Picto</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for vigilance in vigilances %}
            <tr>
                <td>{{ vigilance.id }}</td>
                <td>{{ vigilance.definition }}</td>
                <td>{{ vigilance.picto }}</td>
                <td>

                    {{ action_buttons('app_vigilance_show', 'app_vigilance_edit', vigilance.id) }}

                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_vigilance_new') }}">Creer</a>
{% endblock %}
