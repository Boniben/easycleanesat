{% extends 'base.html.twig' %}

{% block title %}Creer une zone
{% endblock %}

{% block body %}
	<div class="page-header">
		<h1>Creer une zone</h1>
	</div>

	{{ form_start(form, {'attr': {'id': 'zone-form'}}) }}

	<div class="form-card">
		<div class="form-row">
			{{ form_label(form.nom) }}
			{{ form_widget(form.nom) }}
		</div>

		<div class="form-row">
			{{ form_label(form.sitesClient) }}
			{{ form_widget(form.sitesClient) }}
		</div>

		<div style="display:none">
			{{ form_widget(form.typeZone) }}
		</div>

		<div class="form-row">
			<label>Type de zone</label>
			<div style="display:flex; gap:8px;">
				<input type="text" id="search-type-zone" placeholder="Rechercher un type de zone (ex: sanitaire, bureau, cuisine...)" style="flex:1; padding:10px; border:1px solid var(--color-border); border-radius:8px; font-size:0.95rem;">
				<button type="button" id="btn-search-zone" class="btn btn-primary">Rechercher</button>
			</div>
		</div>

		<div id="selected-type-zone" style="margin-bottom:12px;"></div>
	</div>

	<div id="results-type-zone" style="display:grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap:8px; margin:16px 0;"></div>

	<div style="margin-top:16px;">
		<button class="btn btn-primary" type="submit">Sauvegarder</button>
		<a href="{{ path('app_client_index') }}" class="btn btn-secondary">Annuler</a>
	</div>

	{{ form_end(form) }}

	<a href="{{ path('app_client_index') }}" class="btn btn-secondary" style="margin-top:12px;">Retour a la liste</a>

	<script>
		const searchInput = document.getElementById('search-type-zone');
const resultsContainer = document.getElementById('results-type-zone');
const selectedContainer = document.getElementById('selected-type-zone');
const typeZoneSelect = document.getElementById('{{ form.typeZone.vars.id }}');
let selectedId = typeZoneSelect.value || null;

if (selectedId) {
const opt = typeZoneSelect.querySelector('option[value="' + selectedId + '"]');
if (opt) 
showSelected(selectedId, opt.textContent, '');

}

function doSearch() {
const query = searchInput.value.trim();
if (query.length < 2) {
resultsContainer.innerHTML = '';
return;
}

fetch('{{ path("api_type_zone_search") }}?q=' + encodeURIComponent(query)).then(r => r.json()).then(data => {
resultsContainer.innerHTML = '';
if (data.length === 0) {
resultsContainer.innerHTML = '<p style="color:var(--color-text-secondary); grid-column:1/-1;">Aucun type trouve</p>';
return;
}
data.forEach(item => {
const card = document.createElement('div');
const isSelected = selectedId == item.id;
card.style.cssText = 'padding:8px 10px; border:2px solid ' + (
isSelected ? 'var(--color-primary)' : 'var(--color-border)'
) + '; border-radius:6px; cursor:pointer; text-align:center; transition:all 0.15s; background:' + (
isSelected ? '#dbe8f4' : 'var(--color-surface)'
) + ';';
card.innerHTML = (item.picto ? '<img src=" {{ asset("PictoTypeZonePNG/") }}' + item.picto + '" alt="' + item.nom + '" style="max-height:50px; margin-bottom:4px;">' : '') + '<div style="font-weight:600; color:var(--color-primary); font-size:0.85rem;">' + item.nom + '</div>' + (
item.description ? '<div style="color:var(--color-text-secondary); font-size:0.7rem; margin-top:2px;">' + item.description + '</div>' : ''
);

card.addEventListener('click', () => {
selectTypeZone(item.id, item.nom, item.description);
resultsContainer.querySelectorAll('div[data-tz]').forEach(c => {
c.style.borderColor = 'var(--color-border)';
c.style.background = 'var(--color-surface)';
});
card.style.borderColor = 'var(--color-primary)';
card.style.background = '#dbe8f4';
});
card.addEventListener('mouseenter', () => {
if (selectedId != item.id) 
card.style.borderColor = 'var(--color-primary)';

});
card.addEventListener('mouseleave', () => {
if (selectedId != item.id) 
card.style.borderColor = 'var(--color-border)';

});
card.setAttribute('data-tz', item.id);
resultsContainer.appendChild(card);
});
});
}

document.getElementById('btn-search-zone').addEventListener('click', doSearch);
searchInput.addEventListener('keydown', function (e) {
if (e.key === 'Enter') {
e.preventDefault();
doSearch();
}
});

function selectTypeZone(id, nom, desc) {
selectedId = id;
typeZoneSelect.value = id;
showSelected(id, nom, desc);
}

function showSelected(id, nom, desc) {
selectedContainer.innerHTML = '<div style="display:inline-flex; align-items:center; gap:8px; padding:6px 12px; background:#dbe8f4; border:2px solid var(--color-primary); border-radius:6px;">' + '<strong style="color:var(--color-primary); font-size:0.85rem;">' + nom + '</strong>' + '<button type="button" onclick="clearSelection()" style="background:none; border:none; color:var(--color-text-secondary); cursor:pointer; font-size:1rem;">x</button>' + '</div>';
}

function clearSelection() {
selectedId = null;
typeZoneSelect.value = '';
selectedContainer.innerHTML = '';
resultsContainer.querySelectorAll('div[data-tz]').forEach(c => {
c.style.borderColor = 'var(--color-border)';
c.style.background = 'var(--color-surface)';
});
}
	</script>
{% endblock %}
