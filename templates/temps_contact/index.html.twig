{% from '_macros/action_buttons.html.twig' import action_buttons %}
{% extends 'base.html.twig' %}

{% block title %}Temps de contact{% endblock %}

{% block body %}
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h1>Temps de contact</h1>
        <a href="{{ path('app_temps_contact_new') }}" class="btn btn-success" style="font-size: 16px; padding: 10px 20px;">+ Creer</a>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Temps de contact</th>
                <th>Picto</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for temps_contact in temps_contacts %}
            <tr>
                <td>{{ temps_contact.id }}</td>
                <td>{{ temps_contact.tempsContact }}</td>
                <td>
                    <img src="{{ asset('PictoTempContactPNG/' ~ temps_contact.id ~ '.png') }}" alt="Pictogramme {{ temps_contact.tempsContact }}" style="max-height: 40px;">
                </td>
                <td>

                    {{ action_buttons('app_temps_contact_show', 'app_temps_contact_edit', temps_contact.id) }}

                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">Aucun enregistrement trouve</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
