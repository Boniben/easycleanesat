{% extends 'base.html.twig' %}

{% block title %}Modifier Temps de contact{% endblock %}

{% block body %}
    <h1>Modifier Temps de contact</h1>

    <p><strong>Picto actuel :</strong> {{ temps_contact.picto ?: '-' }}</p>

    {{ include('temps_contact/_form.html.twig', {
        'button_label': 'Mettre a jour',
        'hide_picto': true
    }) }}

    <a href="{{ path('app_temps_contact_index') }}">Retour a la liste</a>

    {{ include('temps_contact/_delete_form.html.twig') }}
{% endblock %}
