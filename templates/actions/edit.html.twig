{% extends 'base.html.twig' %}

{% block title %}Modifier Actions{% endblock %}

{% block body %}
    <div class="container-fluid">
        <h1>Modifier une action {{ include('actions/_deactivate_form.html.twig') }}</h1>
        
        <div class="alert-warning-custom">
            ⚠️ <strong>Attention :</strong> Ne pas éditer d'action ! Archiver et créer une nouvelle action sauf cas particulier !
        </div>

        {{ include('actions/_form.html.twig', {'button_label': 'Mettre a jour'}) }}

        <a href="{{ path('app_actions_index') }}">Retour a la liste</a>

        {{ include('actions/_delete_form.html.twig') }}
    </div>
{% endblock %}
