{% from '_macros/action_buttons.html.twig' import action_buttons %}
﻿{% extends 'base.html.twig' %}

{% block title %}VigilanceIntervention index{% endblock %}

{% block body %}
    <h1>VigilanceIntervention index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Detail</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for vigilance_intervention in vigilance_interventions %}
            <tr>
                <td>{{ vigilance_intervention.id }}</td>
                <td>{{ vigilance_intervention.detail }}</td>
                <td>

                    {{ action_buttons('app_vigilance_intervention_show', 'app_vigilance_intervention_edit', vigilance_intervention.id) }}

                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_vigilance_intervention_new') }}">Creer</a>
{% endblock %}
