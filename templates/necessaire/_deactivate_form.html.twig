<form method="post" action="{{ path('app_necessaire_toggle_actif', {'id': necessaire.id}) }}" style="display:inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('toggle_actif' ~ necessaire.id) }}">
    <button type="submit" class="btn {% if necessaire.actif %}btn-success{% else %}btn-danger{% endif %}" onclick="return confirm('{% if necessaire.actif %}Confirmer la désactivation ?\n\nToutes les actions qui comportent ce nécessaire seront automatiquement désactivées.{% else %}Confirmer la réactivation ?{% endif %}');">
        {% if necessaire.actif %}✓ Actif{% else %}✗ Désactivé{% endif %}
    </button>
</form>
