{% extends 'base.html.twig' %}

{% block title %}Moyen de dosage{% endblock %}

{% block body %}
    <h1>Moyen de dosage</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ moyen_dosage.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ moyen_dosage.nom }}</td>
            </tr>
            <tr>
                <th>Code</th>
                <td>{{ moyen_dosage.code }}</td>
            </tr>
            <tr>
                <th>Picto</th>
                <td>
                    <img src="{{ asset('PictoMoyenDosagePNG/' ~ moyen_dosage.id ~ '.png') }}" alt="Picto {{ moyen_dosage.nom }}" style="max-height: 80px;">
                </td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_moyen_dosage_index') }}">Retour a la liste</a>

    <a href="{{ path('app_moyen_dosage_edit', {'id': moyen_dosage.id}) }}">Modifier</a>

    {{ include('moyen_dosage/_delete_form.html.twig') }}
{% endblock %}
