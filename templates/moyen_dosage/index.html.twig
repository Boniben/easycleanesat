{% from '_macros/action_buttons.html.twig' import action_buttons %}
{% extends 'base.html.twig' %}

{% block title %}Moyens de dosage{% endblock %}

{% block body %}
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h1>Moyens de dosage</h1>
        <a href="{{ path('app_moyen_dosage_new') }}" class="btn btn-success" style="font-size: 16px; padding: 10px 20px;">+ Creer</a>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Picto</th>
                <th>Nom</th>
                <th>Code</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for moyen_dosage in moyen_dosages %}
            <tr>
                <td>{{ moyen_dosage.id }}</td>
                <td>
                    <img src="{{ asset('PictoMoyenDosagePNG/' ~ moyen_dosage.id ~ '.png') }}" alt="Pictogramme {{ moyen_dosage.nom }}" style="max-height: 40px;">
                </td>
                <td>{{ moyen_dosage.nom }}</td>
                <td>{{ moyen_dosage.code }}</td>
                <td>

                    {{ action_buttons('app_moyen_dosage_show', 'app_moyen_dosage_edit', moyen_dosage.id) }}

                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">Aucun enregistrement trouve</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
